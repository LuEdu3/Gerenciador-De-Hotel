@model GerenciadorHotel.Models.RelatorioOcupacaoViewModel

<h2>Relatório de Ocupação</h2>
<ul>
    <li>Total de acomodações: @Model.TotalAcomodacoes</li>
    <li>Quartos ocupados: @Model.QuartosOcupados</li>
    <li>Quartos disponíveis: @Model.QuartosDisponiveis</li>
    <li>Taxa de ocupação: @Model.TaxaOcupacao.ToString("F2")%</li>
</ul>

<h3>Reservas Ativas</h3>
<table class="table">
    <thead>
        <tr>
            <th>Acomodação</th>
            <th>Hóspede</th>
            <th>Check-in</th>
            <th>Check-out</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reserva in Model.ReservasAtivas)
        {
            <tr>
                <td>@reserva.Acomodacao?.Nome</td>
                <td>@reserva.NomeHospede @reserva.SobrenomeHospede</td>
                <td>@reserva.DataCheckIn.ToShortDateString()</td>
                <td>@reserva.DataCheckOut.ToShortDateString()</td>
                <td>@reserva.Status</td>
            </tr>
        }
    </tbody>
</table>