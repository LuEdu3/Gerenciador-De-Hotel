@model GerenciadorHotel.ViewModels.EmpresaViewModel

@{
    ViewData["Title"] = "Criar Empresa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">
                        <i class="fas fa-building me-2"></i>Configurar Empresa
                    </h3>
                    <p class="mb-0">Configure as informações da sua empresa para começar</p>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            <h6><i class="fas fa-exclamation-triangle me-2"></i>Corrija os erros abaixo:</h6>
                            <div asp-validation-summary="All" class="mb-0"></div>
                        </div>
                    }

                    <form asp-action="Create" method="post">
                        <div class="mb-4">
                            <h5 class="border-bottom pb-2">
                                <i class="fas fa-info-circle me-2 text-primary"></i>Informações Essenciais
                            </h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="Nome" class="form-label"></label>
                                        <input asp-for="Nome" class="form-control" placeholder="Nome da empresa" required />
                                        <span asp-validation-for="Nome" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="NomeResumido" class="form-label"></label>
                                        <input asp-for="NomeResumido" class="form-control" placeholder="Nome resumido" />
                                        <span asp-validation-for="NomeResumido" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Slogan" class="form-label"></label>
                                <input asp-for="Slogan" class="form-control" placeholder="Slogan da empresa" />
                                <span asp-validation-for="Slogan" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="DescricaoBreve" class="form-label"></label>
                                <textarea asp-for="DescricaoBreve" class="form-control" rows="3" placeholder="Descrição breve da empresa..."></textarea>
                                <span asp-validation-for="DescricaoBreve" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h5 class="border-bottom pb-2">
                                <i class="fas fa-phone me-2 text-success"></i>Contatos Básicos
                            </h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="Telefone" class="form-label"></label>
                                        <input asp-for="Telefone" class="form-control" placeholder="+55 (11) 1234-5678" />
                                        <span asp-validation-for="Telefone" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="Email" class="form-label"></label>
                                        <input asp-for="Email" class="form-control" type="email" placeholder="contato@empresa.com" />
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="HorarioCheckin" class="form-label"></label>
                                        <input asp-for="HorarioCheckin" class="form-control" placeholder="14:00" />
                                        <span asp-validation-for="HorarioCheckin" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="HorarioCheckout" class="form-label"></label>
                                        <input asp-for="HorarioCheckout" class="form-control" placeholder="12:00" />
                                        <span asp-validation-for="HorarioCheckout" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-lightbulb me-2"></i>
                            <strong>Dica:</strong> Você pode adicionar mais informações (endereço, redes sociais, fotos, etc.) 
                            depois de criar a empresa, através da página de gerenciamento.
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>Criar Empresa
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
