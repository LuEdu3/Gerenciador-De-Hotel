@model GerenciadorHotel.Models.Acomodacao
@using GerenciadorHotel.Models
@using GerenciadorHotel.Extensions

@{
    ViewData["Title"] = "Detalhes da Acomodação";
}

<div class="accommodation-details">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-8">
                <!-- Galeria de Imagens Premium -->
                @if (Model.Imagens != null && Model.Imagens.Any())
                {
                    <div class="details-carousel mb-4">
                        <div id="carouselImages" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
                            <!-- Indicadores -->
                            @if (Model.Imagens.Count > 1)
                            {
                                <div class="carousel-indicators">
                                    @for (int i = 0; i < Model.Imagens.Count; i++)
                                    {
                                        <button type="button" data-bs-target="#carouselImages" data-bs-slide-to="@i" 
                                                class="@(i == 0 ? "active" : "")" 
                                                aria-current="@(i == 0 ? "true" : "false")" 
                                                aria-label="Slide @(i + 1)"></button>
                                    }
                                </div>
                            }
                            
                            <!-- Imagens -->
                            <div class="carousel-inner">
                                @for (int i = 0; i < Model.Imagens.Count; i++)
                                {
                                    <div class="carousel-item @(i == 0 ? "active" : "")">
                                        <img src="@Model.Imagens.ElementAt(i).ImagemUrl" 
                                             class="d-block w-100 carousel-image" 
                                             alt="@Model.Nome - Imagem @(i + 1)">
                                        <div class="carousel-overlay">
                                            <div class="carousel-overlay-content">
                                                <span class="image-counter">
                                                    <i class="fas fa-camera me-1"></i>
                                                    @(i + 1) de @Model.Imagens.Count
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            
                            <!-- Controles de Navegação -->
                            @if (Model.Imagens.Count > 1)
                            {
                                <button class="carousel-control-prev" type="button" data-bs-target="#carouselImages" data-bs-slide="prev">
                                    <div class="carousel-control-icon">
                                        <i class="fas fa-chevron-left"></i>
                                    </div>
                                    <span class="visually-hidden">Anterior</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carouselImages" data-bs-slide="next">
                                    <div class="carousel-control-icon">
                                        <i class="fas fa-chevron-right"></i>
                                    </div>
                                    <span class="visually-hidden">Próximo</span>
                                </button>
                            }
                        </div>
                    </div>
                }

                <!-- Informações da Acomodação -->
                <div class="accommodation-info-card">
                    <div class="card-header">
                        <h1 class="accommodation-title">@Model.Nome</h1>
                        <div class="accommodation-rating">
                            @for (int i = 0; i < 5; i++)
                            {
                                <i class="fas fa-star"></i>
                            }
                            <span class="rating-text">Quarto Premium</span>
                        </div>
                    </div>
                    
                    <div class="card-body">
                        <p class="accommodation-description">@Model.Descricao</p>

                        <!-- Informações Principais -->
                        <div class="accommodation-specs">
                            <div class="spec-item">
                                <div class="spec-icon">
                                    <i class="fas fa-bed"></i>
                                </div>
                                <div class="spec-content">
                                    <span class="spec-title">Camas</span>
                                    <span class="spec-value">@Model.QuantidadeCamas</span>
                                </div>
                            </div>
                            <div class="spec-item">
                                <div class="spec-icon">
                                    <i class="fas fa-users"></i>
                                </div>
                                <div class="spec-content">
                                    <span class="spec-title">Capacidade</span>
                                    <span class="spec-value">Até @Model.QuantidadeCamas pessoas</span>
                                </div>
                            </div>
                            <div class="spec-item">
                                <div class="spec-icon">
                                    <i class="fas fa-moon"></i>
                                </div>
                                <div class="spec-content">
                                    <span class="spec-title">Mínimo</span>
                                    <span class="spec-value">@Model.MinimoNoites noites</span>
                                </div>
                            </div>
                            <div class="spec-item">
                                <div class="spec-icon">
                                    <i class="fas fa-ruler-combined"></i>
                                </div>
                                <div class="spec-content">
                                    <span class="spec-title">Área</span>
                                    <span class="spec-value">25m²</span>
                                </div>
                            </div>
                        </div>

                        <!-- Amenidades Premium -->
                        @if (Model.AcomodacaoAmenidades != null && Model.AcomodacaoAmenidades.Any())
                        {
                            <div class="amenities-section">
                                <h3 class="amenities-title">
                                    <i class="fas fa-star me-2"></i>
                                    Amenidades e Serviços
                                </h3>
                                <div class="amenities-grid">
                                    @foreach (var amenidade in Model.AcomodacaoAmenidades)
                                    {
                                        <div class="amenity-item">
                                            <div class="amenity-icon">
                                                <i class="@(amenidade.Amenidade?.GetIconClass() ?? "fas fa-star")"></i>
                                            </div>
                                            <div class="amenity-content">
                                                <span class="amenity-name">@amenidade.Amenidade?.Nome</span>
                                                <span class="amenity-description">@(amenidade.Amenidade?.GetDescription() ?? "Amenidade disponível")</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar de Reserva Premium -->
            <div class="col-lg-4">
                <div class="reservation-card">
                    <div class="price-display">
                        <div class="price-main">
                            <span class="price-value">@Model.Preco.ToString("C")</span>
                            <span class="price-period">por noite</span>
                        </div>
                        <div class="price-savings">
                            <i class="fas fa-tag me-1"></i>
                            Melhor preço garantido
                        </div>
                    </div>

                    <div class="reservation-status">
                        <div class="status-item">
                            <span class="status-label">Status:</span>
                            <span class="badge status-badge @(Model.Status switch {
                                GerenciadorHotel.Models.StatusAcomodacao.Disponivel => "status-available",
                                GerenciadorHotel.Models.StatusAcomodacao.Ocupada => "status-occupied",
                                GerenciadorHotel.Models.StatusAcomodacao.Manutencao => "status-maintenance",
                                _ => "status-unavailable"
                            })">
                                <i class="fas @(Model.Status switch {
                                    GerenciadorHotel.Models.StatusAcomodacao.Disponivel => "fa-check-circle",
                                    GerenciadorHotel.Models.StatusAcomodacao.Ocupada => "fa-times-circle",
                                    GerenciadorHotel.Models.StatusAcomodacao.Manutencao => "fa-tools",
                                    _ => "fa-exclamation-circle"
                                }) me-1"></i>
                                @(Model.Status == StatusAcomodacao.Disponivel ? "Disponível" : Model.Status.ToString())
                            </span>
                        </div>
                    </div>

                    <div class="reservation-actions">
                        @if (Model.Status == StatusAcomodacao.Disponivel)
                        {
                            <button type="button" class="btn btn-reserve" onclick="handleReservaClick(event, @Model.Id)">
                                <i class="fas fa-calendar-check me-2"></i>
                                Reservar Agora
                            </button>
                            <div class="reserve-note">
                                <i class="fas fa-info-circle me-1"></i>
                                Confirmação instantânea
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-reserve btn-disabled" disabled>
                                <i class="fas fa-times me-2"></i>
                                Indisponível
                            </button>
                        }
                    </div>

                    <div class="additional-info">
                        <div class="info-item">
                            <i class="fas fa-shield-alt text-success me-2"></i>
                            <span>Cancelamento grátis até 24h antes</span>
                        </div>
                        <div class="info-item">
                            <i class="fas fa-clock text-primary me-2"></i>
                            <span>Check-in: 14h | Check-out: 12h</span>
                        </div>
                        <div class="info-item">
                            <i class="fas fa-utensils text-warning me-2"></i>
                            <span>Café da manhã incluído</span>
                        </div>
                    </div>

                    <div class="navigation-actions">
                        <a href="@Url.Action("Acomodacao", "Home")" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-arrow-left me-2"></i>
                            Ver Outras Acomodações
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
