<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Gerenciamento de Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GerenciadorHotel.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,700&display=swap" rel="stylesheet">
</head>

<body class="d-flex flex-column min-vh-100">
    <!-- Header -->
    <!-- Cabeçalho Moderno -->
    <header class="header-modern py-3">
        <div class="container">
            <nav class="navbar navbar-expand-lg navbar-light p-0">
                <a class="navbar-brand navbar-brand-modern" asp-area="" asp-controller="Home" asp-action="Index">
                    Sereno<span>Hotel</span>
                </a>
                <button class="navbar-toggler-modern" type="button" data-bs-toggle="collapse" data-bs-target="#navbarModern"
                    aria-controls="navbarModern" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon-modern"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarModern">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link nav-link-modern @(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")"
                                asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-modern @(ViewContext.RouteData.Values["controller"].ToString() == "Acomodacoes" ? "active" : "")"
                                asp-controller="Acomodacoes" asp-action="Index">Acomodações</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-modern @(ViewContext.RouteData.Values["action"].ToString() == "Sobre" ? "active" : "")"
                                asp-area="" asp-controller="Home" asp-action="Sobre">Sobre</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-modern @(ViewContext.RouteData.Values["action"].ToString() == "Contato" ? "active" : "")"
                                asp-area="" asp-controller="Home" asp-action="Contato">Contato</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-none d-lg-block">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-header">Sair</button>
                                </form>
                            </li>
                            <li class="nav-item d-none d-lg-block">
                                <a href="#" class="btn btn-header btn-header-accent">Reservar</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item d-none d-lg-block">
                                <a class="btn btn-header" asp-area="Identity" asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item d-none d-lg-block">
                                <a href="#" class="btn btn-header btn-header-accent">Reservar</a>
                            </li>
                        }
                        <!-- Botões para mobile -->
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-lg-none">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                    <button type="submit" class="nav-link nav-link-modern">Sair</button>
                                </form>
                            </li>
                            <li class="nav-item d-lg-none">
                                <a class="nav-link nav-link-modern" href="#">Reservar</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item d-lg-none">
                                <a class="nav-link nav-link-modern" asp-area="Identity" asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item d-lg-none">
                                <a class="nav-link nav-link-modern" href="#">Reservar</a>
                            </li>
                        }
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle nav-link-modern" href="#" role="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">Administração</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Usuarios" asp-action="Index">Gerenciar Usuários</a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="#">Gerenciar Amenidades</a></li>
                                    <li><a class="dropdown-item" href="#">Gerenciar Países</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="#">Relatórios</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
                <!-- Ícone de usuário para login (desktop) -->
                <div class="d-flex align-items-center ms-3 d-none d-lg-block">
                    <i class="bi bi-person user-icon" data-bs-toggle="modal" data-bs-target="#loginModal"></i>
                </div>
            </nav>
        </div>
    </header>

    <div class="container-fluid p-0 flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-section bg-dark text-white pt-5 pb-4 mt-auto">
        <div class="container">
            <div class="row g-4">
                <!-- Logo e Sobre -->
                <div class="col-lg-4 col-md-6 mb-4 mb-lg-0">
                    <div class="footer-brand d-flex align-items-center mb-3">
                        <h2 class="navbar-brand-modern m-0">Sereno<span>Hotel</span></h2>
                    </div>
                    <p class="mb-3">O Sereno Hotel oferece uma experiência única de hospedagem, combinando luxo contemporâneo com um serviço personalizado e atenção aos detalhes.</p>
                    <div class="social-icons">
                        <a href="#" class="text-white me-3"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="text-white me-3"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-white me-3"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-white"><i class="fab fa-tripadvisor"></i></a>
                    </div>
                </div>
                <!-- Links Rápidos -->
                <div class="col-lg-2 col-md-6 mb-4 mb-md-0">
                    <h5 class="text-uppercase mb-4" style="color: var(--accent-color);">Links Rápidos</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-white text-decoration-none">Home</a></li>
                        <li class="mb-2"><a href="#" class="text-white text-decoration-none">Acomodações</a></li>
                        <li class="mb-2"><a href="#" class="text-white text-decoration-none">Serviços</a></li>
                        <li class="mb-2"><a href="#" class="text-white text-decoration-none">Galeria</a></li>
                        <li class="mb-2"><a href="#" class="text-white text-decoration-none">Contato</a></li>
                    </ul>
                </div>
                <!-- Contato -->
                <div class="col-lg-3 col-md-6 mb-4 mb-md-0">
                    <h5 class="text-uppercase mb-4" style="color: var(--accent-color);">Contato</h5>
                    <ul class="list-unstyled">
                        <li class="mb-3 d-flex">
                            <i class="fas fa-map-marker-alt me-3" style="color: var(--accent-color);"></i>
                            <span>Av. Beira Mar, 1234 - Praia do Sereno, BR</span>
                        </li>
                        <li class="mb-3 d-flex">
                            <i class="fas fa-phone me-3" style="color: var(--accent-color);"></i>
                            <span>+55 (48) 3333-4444</span>
                        </li>
                        <li class="mb-3 d-flex">
                            <i class="fas fa-envelope me-3" style="color: var(--accent-color);"></i>
                            <span>contato@serenohotel.com</span>
                        </li>
                        <li class="d-flex">
                            <i class="fas fa-clock me-3" style="color: var(--accent-color);"></i>
                            <span>24h por dia, 7 dias por semana</span>
                        </li>
                    </ul>
                </div>
                <!-- Newsletter -->
                <div class="col-lg-3 col-md-6">
                    <h5 class="text-uppercase mb-4" style="color: var(--accent-color);">Newsletter</h5>
                    <p class="mb-3">Assine nossa newsletter para receber ofertas exclusivas e novidades.</p>
                    <form class="mb-3">
                        <div class="input-group">
                            <input type="email" class="form-control" placeholder="Seu e-mail" aria-label="Seu e-mail">
                            <button class="btn btn-accent" type="submit">Assinar</button>
                        </div>
                    </form>
                    <div class="payment-methods">
                        <p class="small mb-2">Métodos de pagamento:</p>
                        <div class="d-flex flex-wrap">
                            <i class="fab fa-cc-visa fa-2x me-2 mb-2" style="color: #f5f5dc;"></i>
                            <i class="fab fa-cc-mastercard fa-2x me-2 mb-2" style="color: #f5f5dc;"></i>
                            <i class="fab fa-cc-amex fa-2x me-2 mb-2" style="color: #f5f5dc;"></i>
                            <i class="fab fa-cc-paypal fa-2x me-2 mb-2" style="color: #f5f5dc;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <hr class="my-4" style="border-color: rgba(255,255,255,0.1);">
            <!-- Rodapé inferior -->
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="small mb-0">&copy; 2023 Sereno Hotel. Todos os direitos reservados.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <ul class="list-inline small mb-0">
                        <li class="list-inline-item"><a href="#" class="text-white text-decoration-none">Política de Privacidade</a></li>
                        <li class="list-inline-item mx-2">•</li>
                        <li class="list-inline-item"><a href="#" class="text-white text-decoration-none">Termos de Uso</a></li>
                        <li class="list-inline-item mx-2">•</li>
                        <li class="list-inline-item"><a href="#" class="text-white text-decoration-none">Mapa do Site</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <!-- Modal de Login/Cadastro (apenas UMA vez!) -->
    <div class="modal fade login-modal" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="loginModalLabel">Acesse sua conta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <ul class="nav nav-tabs login-tabs mb-4" id="loginTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="login-tab" data-bs-toggle="tab" data-bs-target="#login" type="button" role="tab" aria-controls="login" aria-selected="true">Login</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="register-tab" data-bs-toggle="tab" data-bs-target="#register" type="button" role="tab" aria-controls="register" aria-selected="false">Cadastre-se</button>
                        </li>
                    </ul>
                    <div class="tab-content" id="loginTabsContent">
                        <!-- Aba de Login -->
                        <div class="tab-pane fade show active" id="login" role="tabpanel" aria-labelledby="login-tab">
                            <form class="login-form">
                                <div class="mb-3">
                                    <input type="email" class="form-control" id="loginEmail" placeholder="E-mail" required>
                                </div>
                                <div class="mb-3">
                                    <input type="password" class="form-control" id="loginPassword" placeholder="Senha" required>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="rememberMe">
                                    <label class="form-check-label" for="rememberMe">Lembrar-me</label>
                                </div>
                                <button type="submit" class="btn btn-login">Entrar</button>
                                
                                <div class="login-divider">
                                    <span>ou</span>
                                </div>
                                
                                <div class="social-login">
                                    <button type="button" class="btn btn-google">
                                        <i class="fab fa-google"></i> Continuar com Google
                                    </button>
                                    <button type="button" class="btn btn-facebook">
                                        <i class="fab fa-facebook-f"></i> Continuar com Facebook
                                    </button>
                                </div>
                                
                                <div class="forgot-password">
                                    <a href="#">Esqueceu sua senha?</a>
                                </div>
                            </form>
                        </div>
                        
                        <!-- Aba de Cadastro -->
                        <div class="tab-pane fade" id="register" role="tabpanel" aria-labelledby="register-tab">
                            <form class="login-form">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <input type="text" class="form-control" id="firstName" placeholder="Nome" required>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <input type="text" class="form-control" id="lastName" placeholder="Sobrenome" required>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <input type="email" class="form-control" id="registerEmail" placeholder="E-mail" required>
                                </div>
                                <div class="mb-3">
                                    <input type="password" class="form-control" id="registerPassword" placeholder="Senha" required>
                                </div>
                                <div class="mb-3">
                                    <input type="password" class="form-control" id="confirmPassword" placeholder="Confirmar Senha" required>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="agreeTerms" required>
                                    <label class="form-check-label" for="agreeTerms">
                                        Eu concordo com os <a href="#" class="text-decoration-none">Termos de Serviço</a> e <a href="#" class="text-decoration-none">Política de Privacidade</a>
                                    </label>
                                </div>
                                <button type="submit" class="btn btn-login">Cadastrar</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function abrirLoginModal() {
            var modal = new bootstrap.Modal(document.getElementById('loginModal'));
            modal.show();
        }

        // Só dispara o modal se o usuário NÃO estiver autenticado
        document.querySelectorAll('.btn-header, .btn-header-accent, .user-icon, .btn-room').forEach(function(el) {
            el.addEventListener('click', function(e) {
                var usuarioLogado = '@User.Identity.IsAuthenticated'.toLowerCase() === 'true';
                if (!usuarioLogado) {
                    abrirLoginModal();
                    e.preventDefault();
                }
                // Se estiver logado, segue o fluxo normal (ex: reservar)
            });
        });

        // Remove backdrop e classe modal-open caso fique preso
        document.getElementById('loginModal').addEventListener('hidden.bs.modal', function () {
            document.body.classList.remove('modal-open');
            document.querySelectorAll('.modal-backdrop').forEach(function (el) {
                el.parentNode.removeChild(el);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
