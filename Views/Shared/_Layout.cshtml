<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Gerenciamento de Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GerenciadorHotel.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,700&display=swap" rel="stylesheet">
</head>

<body>
    <!-- Header -->
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg custom-navbar navbar-dark">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="https://static.wixstatic.com/media/b87f83_9f4625b043a944daaf5fddefc7d73d0e~mv2.png/v1/fill/w_80,h_80,al_c,q_85,enc_avif,quality_auto/logo-pousada-quinta-do-ypua.png" alt="Logo Quinta do Ypuã" style="height:48px; margin-right:12px;">
                    <span class="fw-bold">Quinta do Ypuã</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-2">
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-area="" asp-controller="Home" asp-action="Sobre">Sobre</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-area="" asp-controller="Home" asp-action="Contato">Contato</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link custom-nav-link" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                            </li>
                        }
                        @if (User.IsInRole("Administrador") || User.IsInRole("Recepcionista"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle custom-nav-link" href="#" role="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">Reservas</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Reservas" asp-action="Index">Lista de Reservas</a>
                                    </li>
                                    <li><a class="dropdown-item" asp-controller="Reservas" asp-action="Create">Nova Reserva</a>
                                    </li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle custom-nav-link" href="#" role="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">Acomodações</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Acomodacoes" asp-action="Index">Lista de Acomodações
                                            </a></li>
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Acomodacoes" asp-action="Create">Nova Acomodação
                                            </a></li>
                                    }
                                </ul>
                            </li>
                        }
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle custom-nav-link" href="#" role="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">Administração</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Usuarios" asp-action="Index">Gerenciar Usuários</a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="#">Gerenciar Amenidades</a></li>
                                    <li><a class="dropdown-item" href="#">Gerenciar Países</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="#">Relatórios</a></li>
                                </ul>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated != true)
                        {
                            <li class="nav-item">
                                <a class="nav-link custom-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacidade</a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex">
                        <a class="btn btn-login" asp-area="Identity" asp-page="/Account/Login">Login/Cadastro</a>
                    </div>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light">
        <div class="container py-3">
            <div class="row">
                <div class="col-md-6">
                    &copy; 2025 - Sistema de Gerenciamento de Hotel
                </div>
                <div class="col-md-6 text-end">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Política de Privacidade</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
