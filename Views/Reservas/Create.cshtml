@model GerenciadorHotel.Models.Reserva
@{
    ViewData["Title"] = "Criar Reserva";
}
<style>
    .reserva-container {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
        padding: 32px;
        max-width: 950px;
        margin: 40px auto;
        display: flex;
        flex-wrap: wrap;
    }

    .reserva-form {
        flex: 2;
        min-width: 320px;
        margin-right: 32px;
    }

    .reserva-resumo {
        flex: 1;
        min-width: 260px;
        background: #fafafa;
        border-radius: 8px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
        height: fit-content;
    }

    .btn-checkout {
        background: #2d9cdb;
        color: #fff;
        border-radius: 24px;
        padding: 10px 32px;
        font-size: 1.1rem;
        border: none;
        margin-top: 16px;
        transition: background 0.2s;
    }

    .btn-checkout:hover {
        background: #217dbb;
    }

    /* Melhorias no select de países */
    #country-select {
        height: 45px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 14px;
        transition: border-color 0.2s;
    }

    #country-select:focus {
        border-color: #2d9cdb;
        box-shadow: 0 0 0 0.2rem rgba(45, 156, 219, 0.25);
    }

    #country-select option {
        padding: 8px;
    }

    .form-label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 8px;
    }
</style>
<div class="reserva-container">
    <div class="reserva-form">
        <h4 class="mb-4">Detalhes do Hóspede</h4>
        <form asp-action="Create" method="post">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="NomeHospede" class="form-label"></label>
                    <input asp-for="NomeHospede" class="form-control" />
                    <span asp-validation-for="NomeHospede" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="SobrenomeHospede" class="form-label"></label>
                    <input asp-for="SobrenomeHospede" class="form-control" />
                    <span asp-validation-for="SobrenomeHospede" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Telefone" class="form-label"></label>
                    <input asp-for="Telefone" class="form-control" />
                    <span asp-validation-for="Telefone" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="PaisId" class="form-label"></label>
                    <select asp-for="PaisId" class="form-select" asp-items="ViewBag.PaisId" id="country-select">
                        <option value="">Selecionar País</option>
                    </select>
                    <span asp-validation-for="PaisId" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PedidosEspeciais" class="form-label"></label>
                    <input asp-for="PedidosEspeciais" class="form-control" />
                    <span asp-validation-for="PedidosEspeciais" class="text-danger"></span>
                </div>
            </div>
            <hr />
            <h4 class="mb-3">Dados da Reserva</h4>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="AcomodacaoId" class="form-label"></label>
                    <select asp-for="AcomodacaoId" class="form-select" asp-items="ViewBag.AcomodacaoId"></select>
                    <span asp-validation-for="AcomodacaoId" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DataCheckIn" class="form-label"></label>
                    <input asp-for="DataCheckIn" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="DataCheckIn" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DataCheckOut" class="form-label"></label>
                    <input asp-for="DataCheckOut" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="DataCheckOut" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="NumeroHospedes" class="form-label"></label>
                    <input asp-for="NumeroHospedes" class="form-control" type="number" min="1" max="10" />
                    <span asp-validation-for="NumeroHospedes" class="text-danger"></span>
                        <span id="limite-hospedes-info" class="text-info small"></span>
                </div>
            </div>
            <div class="form-group mt-4">
                <button type="submit" class="btn-checkout">Continuar para o checkout</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
            <div class="mt-3" style="font-size:0.95em;color:#888;">
                * Ao finalizar esta reserva, eu reconheço que li e aceito a <a href="#" target="_blank">Política da
                    Propriedade</a>.
            </div>
        </form>
    </div>
    <div class="reserva-resumo">
        <h5 class="mb-3">Resumo Da Reserva</h5>
        @if (ViewBag.AcomodacaoSelecionada != null)
        {
            <img src="@ViewBag.AcomodacaoSelecionada.ImagemPrincipalUrl" alt="Imagem da acomodação"
                class="img-fluid rounded mb-3" style="max-height:160px;object-fit:cover;" />
            <div><strong>Tipo de Acomodação:</strong> @ViewBag.AcomodacaoSelecionada.Nome</div>
                <div><strong>Limite Máximo de Hóspedes:</strong> @ViewBag.AcomodacaoSelecionada.QuantidadeMaximaHospedes</div>
            <div><strong>Datas:</strong> @Model.DataCheckIn.ToString("dd/MM/yyyy") -
                @Model.DataCheckOut.ToString("dd/MM/yyyy")</div>
            <div><strong>Nº de noites:</strong> @Model.QuantidadeNoites</div>
            <div><strong>Hóspedes:</strong> @Model.NumeroHospedes</div>
            <hr />
            <div><strong>Subtotal:</strong> @Model.ValorTotal.ToString("C")</div>
            <div><strong>Impostos (0%):</strong> R$0</div>
            <div class="mt-2"><strong>Total:</strong> @Model.ValorTotal.ToString("C")</div>
        }
        else
        {
            <div class="text-muted">Selecione uma acomodação para ver o resumo.</div>
        }
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            // Adicionar filtro de busca no select de países
            var countriesSelect = $('#country-select');

            // Melhorar a usabilidade do select de países
            countriesSelect.on('change', function () {
                var selectedText = $(this).find('option:selected').text();
                console.log('País selecionado:', selectedText);
            });

            // Destacar Brasil como primeira opção
            var brasilOption = countriesSelect.find('option').filter(function () {
                return $(this).text().toLowerCase().includes('brasil');
            });

            if (brasilOption.length > 0) {
                brasilOption.remove();
                countriesSelect.find('option:first').after(brasilOption);
            }

            // Bloquear datas ocupadas no calendário
                var datasOcupadasPorAcomodacao = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.DatasOcupadasPorAcomodacao ?? new Dictionary<int, object>()));
                console.log('Datas ocupadas recebidas:', datasOcupadasPorAcomodacao);
            var acomodacaoSelect = $('select[name="AcomodacaoId"]');
            var checkInInput = $('input[name="DataCheckIn"]');
            var checkOutInput = $('input[name="DataCheckOut"]');
                var limiteHospedesInfo = $('#limite-hospedes-info');

                function atualizarLimiteHospedes() {
                    var acomodacoes = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Acomodacoes ?? new List<object>()));
                    var acomodacaoId = acomodacaoSelect.val();
                    var acomodacao = acomodacoes.find(a => a.Id == parseInt(acomodacaoId));
                    if (acomodacao) {
                        limiteHospedesInfo.text('Limite máximo: ' + acomodacao.QuantidadeMaximaHospedes + ' hóspedes');
                        $('input[name="NumeroHospedes"]').attr('max', acomodacao.QuantidadeMaximaHospedes);
                    } else {
                        limiteHospedesInfo.text('');
                        $('input[name="NumeroHospedes"]').attr('max', 10);
                    }
                }
                acomodacaoSelect.on('change', atualizarLimiteHospedes);
                atualizarLimiteHospedes();

            // Definir min dinamicamente como hoje (em tempo real)
            function setMinHoje() {
                var hoje = new Date();
                var hojeStr = hoje.toISOString().split('T')[0];
                checkInInput.attr('min', hojeStr);
                // check-out mínimo: dia seguinte ao check-in ou hoje+1 se vazio
                var diaSeguinte = new Date(hoje);
                diaSeguinte.setDate(diaSeguinte.getDate() + 1);
                checkOutInput.attr('min', diaSeguinte.toISOString().split('T')[0]);
            }
            setMinHoje();

            // Quando check-in muda, atualizar min do check-out para no mínimo o dia seguinte
            checkInInput.on('change', function () {
                if (!this.value) return;
                var selected = new Date(this.value);
                var next = new Date(selected);
                next.setDate(next.getDate() + 1);
                checkOutInput.attr('min', next.toISOString().split('T')[0]);
                // se check-out atual for anterior ao novo min, limpar
                if (checkOutInput.val() && checkOutInput.val() < checkOutInput.attr('min')) {
                    checkOutInput.val('');
                }
            });

            function bloquearDatas(acomodacaoId) {
                    var datas = datasOcupadasPorAcomodacao[acomodacaoId];
                    if (!datas) return;

                    var hoje = new Date();
                    checkInInput[0].min = hoje.toISOString().split('T')[0];
                    checkOutInput[0].min = hoje.toISOString().split('T')[0];

                    // Bloqueio visual: desabilitar datas ocupadas
                    // Para cada intervalo ocupado, criar um array de todas as datas ocupadas
                    var datasBloqueadas = [];
                    datas.forEach(function(intervalo) {
                        var inicio = new Date(intervalo.inicio);
                        var fim = new Date(intervalo.fim);
                        for (var d = new Date(inicio); d <= fim; d.setDate(d.getDate() + 1)) {
                            datasBloqueadas.push(d.toISOString().split('T')[0]);
                        }
                    });

                    // Desabilitar datas ocupadas visualmente
                    checkInInput.off('input').on('input', function () {
                        var dataSelecionada = this.value;
                        if (datasBloqueadas.includes(dataSelecionada)) {
                            this.setCustomValidity('Esta data está ocupada para esta acomodação.');
                        } else {
                            this.setCustomValidity('');
                        }
                    });
                    checkOutInput.off('input').on('input', function () {
                        var dataSelecionada = this.value;
                        if (datasBloqueadas.includes(dataSelecionada)) {
                            this.setCustomValidity('Esta data está ocupada para esta acomodação.');
                        } else {
                            this.setCustomValidity('');
                        }
                    });
                    // Bloqueio visual: impedir seleção manualmente
                    checkInInput.off('keydown').on('keydown', function (e) {
                        var valor = this.value;
                        if (datasBloqueadas.includes(valor)) {
                            e.preventDefault();
                        }
                    });
                    checkOutInput.off('keydown').on('keydown', function (e) {
                        var valor = this.value;
                        if (datasBloqueadas.includes(valor)) {
                            e.preventDefault();
                        }
                    });
            }

            acomodacaoSelect.on('change', function () {
                var acomodacaoId = $(this).val();
                bloquearDatas(acomodacaoId);
            });

            // Inicializar bloqueio se já houver acomodação selecionada
            var inicialId = acomodacaoSelect.val();
            if (inicialId) bloquearDatas(inicialId);

            // === Flatpickr integration for visual disabling of occupied dates ===
            // Load flatpickr via CDN and initialize calendars to visually block dates
            // Note: _Layout already loads jQuery; we include flatpickr here so it's available on this page
            var flatpickrCss = document.createElement('link');
            flatpickrCss.rel = 'stylesheet';
            flatpickrCss.href = 'https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css';
            document.head.appendChild(flatpickrCss);

            var fpScript = document.createElement('script');
            fpScript.src = 'https://cdn.jsdelivr.net/npm/flatpickr';
            fpScript.onload = function () {
                var fpCheckIn, fpCheckOut;

                function intervalsToDisableArray(intervals) {
                    if (!intervals) return [];
                    // Flatpickr accepts objects { from: 'YYYY-MM-DD', to: 'YYYY-MM-DD' }
                    return intervals.map(function (it) {
                        return { from: it.inicio.split('T')[0], to: it.fim.split('T')[0] };
                    });
                }

                function initCalendars() {
                    var hoje = new Date();
                    var amanha = new Date(hoje);
                    amanha.setDate(amanha.getDate() + 1);

                    fpCheckIn = flatpickr(checkInInput[0], {
                        dateFormat: 'Y-m-d',
                        minDate: 'today',
                        disable: []
                    });

                    fpCheckOut = flatpickr(checkOutInput[0], {
                        dateFormat: 'Y-m-d',
                        minDate: amanha.toISOString().split('T')[0],
                        disable: []
                    });

                    // when check-in changes, update minDate for check-out
                    fpCheckIn.config.onChange.push(function (selectedDates) {
                        if (!selectedDates || !selectedDates[0]) return;
                        var next = new Date(selectedDates[0]);
                        next.setDate(next.getDate() + 1);
                        fpCheckOut.set('minDate', next.toISOString().split('T')[0]);
                        // if current checkOut before new min, clear
                        if (checkOutInput.val() && checkOutInput.val() < fpCheckOut.config.minDate) {
                            fpCheckOut.clear();
                        }
                    });
                }

                function updateDisabled(acomodacaoId) {
                    var intervals = datasOcupadasPorAcomodacao[acomodacaoId];
                    var disabled = intervalsToDisableArray(intervals);
                    if (fpCheckIn) fpCheckIn.set('disable', disabled);
                    if (fpCheckOut) fpCheckOut.set('disable', disabled);
                }

                initCalendars();
                if (inicialId) updateDisabled(inicialId);

                acomodacaoSelect.on('change', function () {
                    var id = $(this).val();
                    updateDisabled(id);
                });
            };
            document.body.appendChild(fpScript);
        });
    </script>
}
