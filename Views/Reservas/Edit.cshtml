@model GerenciadorHotel.Models.Reserva
@{
    ViewData["Title"] = "Editar Reserva";
}
<h2>Editar Reserva</h2>
<hr />
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="NomeHospede" class="control-label"></label>
                <input asp-for="NomeHospede" class="form-control" />
                <span asp-validation-for="NomeHospede" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SobrenomeHospede" class="control-label"></label>
                <input asp-for="SobrenomeHospede" class="form-control" />
                <span asp-validation-for="SobrenomeHospede" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Telefone" class="control-label"></label>
                <input asp-for="Telefone" class="form-control" />
                <span asp-validation-for="Telefone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PaisId" class="control-label"></label>
                <select asp-for="PaisId" class="form-control" asp-items="ViewBag.PaisId"></select>
                <span asp-validation-for="PaisId" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="AcomodacaoId" class="control-label"></label>
                <select asp-for="AcomodacaoId" class="form-control" asp-items="ViewBag.AcomodacaoId"></select>
                <span asp-validation-for="AcomodacaoId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DataCheckIn" class="control-label"></label>
                <input asp-for="DataCheckIn" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="DataCheckIn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DataCheckOut" class="control-label"></label>
                <input asp-for="DataCheckOut" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="DataCheckOut" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NumeroHospedes" class="control-label"></label>
                <input asp-for="NumeroHospedes" class="form-control" type="number" min="1" max="10" />
                <span asp-validation-for="NumeroHospedes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PedidosEspeciais" class="control-label"></label>
                <textarea asp-for="PedidosEspeciais" class="form-control" rows="3"></textarea>
                <span asp-validation-for="PedidosEspeciais" class="text-danger"></span>
            </div>
            <div class="form-group">
                    <label asp-for="Status" class="control-label"></label>
                    <select asp-for="Status" class="form-control">
                        @foreach (GerenciadorHotel.Models.StatusReserva status in Enum.GetValues(typeof(GerenciadorHotel.Models.StatusReserva)))
                        {
                            var displayName = GerenciadorHotel.Extensions.EnumExtensions.GetDisplayName(status);
                            <option value="@((int)status)" selected="@(Model.Status == status ? "selected" : null)">@displayName</option>
                        }
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Observacoes" class="control-label"></label>
                <textarea asp-for="Observacoes" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Observacoes" class="text-danger"></span>
            </div>
        </div>
    </div>
    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">Salvar</button>
        @if (User.IsInRole("Hospede"))
        {
            <a asp-action="MinhasReservas" class="btn btn-secondary">Cancelar</a>
            <a asp-action="MinhasReservas" class="btn btn-outline-dark ms-2">Voltar</a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-danger ms-2" onclick="return confirm('Tem certeza que deseja excluir esta reserva?');">Excluir</button>
            </form>
        }
        else
        {
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        }
    </div>
</form>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function () {
            var datasOcupadasPorAcomodacao = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.DatasOcupadasPorAcomodacao ?? new Dictionary<int, object>()));
            var acomodacaoSelect = $('select[name="AcomodacaoId"]');
            var checkInInput = $('input[name="DataCheckIn"]');
            var checkOutInput = $('input[name="DataCheckOut"]');

            function bloquearDatas(acomodacaoId) {
                checkInInput.removeAttr('disabled');
                checkOutInput.removeAttr('disabled');
                checkInInput.find('option').removeAttr('disabled');
                checkOutInput.find('option').removeAttr('disabled');

                var datas = datasOcupadasPorAcomodacao[acomodacaoId];
                if (!datas) return;

                var hoje = new Date();
                checkInInput[0].min = hoje.toISOString().split('T')[0];
                checkOutInput[0].min = hoje.toISOString().split('T')[0];

                checkInInput.off('input').on('input', function () {
                    var dataSelecionada = new Date(this.value);
                    for (var i = 0; i < datas.length; i++) {
                        var inicio = new Date(datas[i].inicio);
                        var fim = new Date(datas[i].fim);
                        if (dataSelecionada >= inicio && dataSelecionada < fim) {
                            this.setCustomValidity('Esta data está ocupada para esta acomodação.');
                            return;
                        }
                    }
                    this.setCustomValidity('');
                });
                checkOutInput.off('input').on('input', function () {
                    var dataSelecionada = new Date(this.value);
                    for (var i = 0; i < datas.length; i++) {
                        var inicio = new Date(datas[i].inicio);
                        var fim = new Date(datas[i].fim);
                        if (dataSelecionada > inicio && dataSelecionada <= fim) {
                            this.setCustomValidity('Esta data está ocupada para esta acomodação.');
                            return;
                        }
                    }
                    this.setCustomValidity('');
                });
            }

            acomodacaoSelect.on('change', function () {
                var acomodacaoId = $(this).val();
                bloquearDatas(acomodacaoId);
            });

            var inicialId = acomodacaoSelect.val();
            if (inicialId) bloquearDatas(inicialId);
        });
    </script>
}
