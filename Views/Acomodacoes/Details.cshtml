@model GerenciadorHotel.Models.Acomodacao

@{
    ViewData["Title"] = "Detalhes da Acomodação";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-house-door"></i> @ViewData["Title"]</h1>
    <div>
        @if (User.IsInRole("Administrador"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Editar
            </a>
        }
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h4><i class="bi bi-info-circle"></i> Informações da Acomodação</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h5 class="text-primary">@Model.Nome</h5>
                        <p class="text-muted">@Model.Descricao</p>
                        
                        <div class="mb-3">
                            <strong>Status:</strong>
                            <span class="badge @(Model.Status switch {
                                GerenciadorHotel.Models.StatusAcomodacao.Disponivel => "bg-success",
                                GerenciadorHotel.Models.StatusAcomodacao.Ocupada => "bg-danger",
                                GerenciadorHotel.Models.StatusAcomodacao.Manutencao => "bg-warning text-dark",
                                _ => "bg-secondary"
                            })">
                                @Model.Status.ToString()
                            </span>
                        </div>

                        <div class="mb-3">
                            <strong>Preço por Noite:</strong>
                            <span class="fs-4 text-success">@Model.Preco.ToString("C")</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <strong><i class="bi bi-bed"></i> Camas:</strong>
                            @if (Model.QuantidadeCamasSolteiro > 0)
                            {
                                <span class="badge bg-info fs-6">@Model.QuantidadeCamasSolteiro cama@(Model.QuantidadeCamasSolteiro > 1 ? "s" : "") de solteiro</span>
                            }
                            @if (Model.QuantidadeCamasSolteiro > 0 && Model.QuantidadeCamasCasal > 0)
                            {
                                <span> </span>
                            }
                            @if (Model.QuantidadeCamasCasal > 0)
                            {
                                <span class="badge bg-info fs-6">@Model.QuantidadeCamasCasal cama@(Model.QuantidadeCamasCasal > 1 ? "s" : "") de casal</span>
                            }
                        </div>

                        <div class="mb-3">
                            <strong><i class="bi bi-calendar"></i> Mínimo de Noites:</strong>
                            <span class="badge bg-primary fs-6">@Model.MinimoNoites</span>
                        </div>

                        <div class="mb-3">
                            <strong>Status Geral:</strong>
                            @if (Model.Ativa)
                            {
                                <span class="badge bg-success">Ativa</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inativa</span>
                            }
                        </div>

                        <div class="mb-3">
                            <strong>Data de Criação:</strong>
                            <span class="text-muted">@Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>

                        @if (Model.DataAtualizacao.HasValue)
                        {
                            <div class="mb-3">
                                <strong>Última Atualização:</strong>
                                <span class="text-muted">@Model.DataAtualizacao.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (Model.AcomodacaoAmenidades.Any())
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h5><i class="bi bi-star"></i> Amenidades</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var amenidade in Model.AcomodacaoAmenidades.Select(aa => aa.Amenidade))
                        {
                            <div class="col-md-4 mb-2">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(amenidade.ImagemUrl))
                                    {
                                        <img src="@amenidade.ImagemUrl" alt="@amenidade.Nome" class="me-2" style="width: 24px; height: 24px; object-fit: cover; border-radius: 4px;">
                                    }
                                    else
                                    {
                                        <i class="bi bi-star me-2"></i>
                                    }
                                    <span>@amenidade.Nome</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">

        <div class="card">
            <div class="card-header">
                <h5><i class="bi bi-camera"></i> Fotos da Acomodação</h5>
            </div>
            <div class="card-body">
                @if (Model.Imagens.Any(i => i.Ativa))
                {
                    var imagensOrdenadas = Model.Imagens.Where(i => i.Ativa).OrderBy(i => i.Ordem).ToList();
                    var principal = imagensOrdenadas.FirstOrDefault(i => i.ImagemUrl == Model.ImagemPrincipalUrl) ?? imagensOrdenadas.First();
                    var outras = imagensOrdenadas.Where(i => i != principal).ToList();
                    <div id="carouselFotos" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img src="@principal.ImagemUrl" class="d-block w-100 rounded" alt="@principal.Titulo" style="max-height:300px; object-fit:cover;">
                                @if (!string.IsNullOrEmpty(principal.Titulo)) { <div class="carousel-caption d-none d-md-block"><h5>@principal.Titulo</h5></div> }
                            </div>
                            @foreach (var img in outras)
                            {
                                <div class="carousel-item">
                                    <img src="@img.ImagemUrl" class="d-block w-100 rounded" alt="@img.Titulo" style="max-height:300px; object-fit:cover;">
                                    @if (!string.IsNullOrEmpty(img.Titulo)) { <div class="carousel-caption d-none d-md-block"><h5>@img.Titulo</h5></div> }
                                </div>
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselFotos" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Anterior</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselFotos" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Próxima</span>
                        </button>
                    </div>
                }
                else
                {
                    <div class="bg-light border rounded p-5 text-center">
                        <i class="bi bi-image display-1 text-muted"></i>
                        <p class="text-muted mt-2">Nenhuma imagem disponível</p>
                    </div>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h6><i class="bi bi-graph-up"></i> Estatísticas</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <small>Reservas Ativas:</small>
                    <span class="badge bg-primary">@Model.Reservas.Count(r => r.Status == GerenciadorHotel.Models.StatusReserva.Confirmada)</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <small>Total de Reservas:</small>
                    <span class="badge bg-info">@Model.Reservas.Count()</span>
                </div>
                <div class="d-flex justify-content-between">
                    <small>Amenidades:</small>
                    <span class="badge bg-success">@Model.AcomodacaoAmenidades.Count()</span>
                </div>
            </div>
        </div>
    </div>
</div>
