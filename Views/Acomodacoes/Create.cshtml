
@model GerenciadorHotel.Models.Acomodacao
@{
	ViewData["Title"] = "Cadastrar Acomodação";
	var amenidades = ViewBag.Amenidades as List<GerenciadorHotel.Models.Amenidade>;
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Create" method="post">
	<div class="mb-3">
		<label asp-for="Nome" class="form-label"></label>
		<input asp-for="Nome" class="form-control" />
		<span asp-validation-for="Nome" class="text-danger"></span>
	</div>
	<div class="mb-3">
		<label asp-for="Descricao" class="form-label"></label>
		<textarea asp-for="Descricao" class="form-control"></textarea>
		<span asp-validation-for="Descricao" class="text-danger"></span>
	</div>
	<div class="mb-3">
		<label asp-for="QuantidadeCamas" class="form-label"></label>
		<input asp-for="QuantidadeCamas" class="form-control" type="number" min="1" max="10" />
		<span asp-validation-for="QuantidadeCamas" class="text-danger"></span>
	</div>
	<div class="mb-3">
		<label for="QuantidadeCamasCasal" class="form-label">Quantidade de Camas de Casal</label>
		<input id="QuantidadeCamasCasal" name="QuantidadeCamasCasal" class="form-control" type="number" min="0" max="10" value="0" />
		<span class="text-muted">(Opcional)</span>
	</div>
	<div class="mb-3">
		<label asp-for="Preco" class="form-label"></label>
		<input asp-for="Preco" class="form-control" type="number" step="0.01" min="0.01" max="9999.99" />
		<span asp-validation-for="Preco" class="text-danger"></span>
	</div>
	<div class="mb-3">
		<label asp-for="MinimoNoites" class="form-label"></label>
		<input asp-for="MinimoNoites" class="form-control" type="number" min="1" max="30" />
		<span asp-validation-for="MinimoNoites" class="text-danger"></span>
	</div>
	<div class="mb-3">
		<label asp-for="Status" class="form-label"></label>
		<select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<GerenciadorHotel.Models.StatusAcomodacao>()"></select>
		<span asp-validation-for="Status" class="text-danger"></span>
	</div>
	<div class="mb-3">
		<label asp-for="ImagemPrincipalUrl" class="form-label"></label>
		<input asp-for="ImagemPrincipalUrl" class="form-control" />
		<span asp-validation-for="ImagemPrincipalUrl" class="text-danger"></span>
	</div>
	<div class="mb-3">
		<label class="form-label">Amenidades</label>
		<div class="row">
			@if (amenidades != null && amenidades.Any())
			{
				foreach (var amenidade in amenidades)
				{
					<div class="col-md-4">
						<div class="form-check">
							<input class="form-check-input" type="checkbox" name="AmenidadesSelecionadas" value="@amenidade.Id" id="amenidade_@amenidade.Id" />
							<label class="form-check-label" for="amenidade_@amenidade.Id">
								@amenidade.Nome
							</label>
						</div>
					</div>
				}
			}
			else
			{
				<div class="col-12"><span class="text-muted">Nenhuma amenidade cadastrada.</span></div>
			}
		</div>
	</div>
	<div class="mb-3 form-check">
		<input asp-for="Ativa" class="form-check-input" />
		<label asp-for="Ativa" class="form-check-label"></label>
	</div>
	<button type="submit" class="btn btn-primary">Salvar</button>
	<a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
	@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
