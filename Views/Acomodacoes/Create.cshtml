@model GerenciadorHotel.Models.Acomodacao
<form asp-action="Create" method="post" class="mb-5">
    <div class="mb-3">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Descricao" class="form-label"></label>
        <textarea asp-for="Descricao" class="form-control"></textarea>
        <span asp-validation-for="Descricao" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="QuantidadeCamas" class="form-label"></label>
        <input asp-for="QuantidadeCamas" class="form-control" type="number" min="1" max="10" />
        <span asp-validation-for="QuantidadeCamas" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label for="QuantidadeCamasCasal" class="form-label">Quantidade de Camas de Casal</label>
    <input id="QuantidadeCamasCasal" name="QuantidadeCamasCasal" class="form-control" type="number" min="0" max="10" />
    </div>
    <div class="mb-3">
        <label asp-for="Preco" class="form-label"></label>
        <input asp-for="Preco" class="form-control" type="number" step="0.01" min="0.01" max="9999.99" />
        <span asp-validation-for="Preco" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="MinimoNoites" class="form-label"></label>
        <input asp-for="MinimoNoites" class="form-control" type="number" min="1" max="30" />
        <span asp-validation-for="MinimoNoites" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<GerenciadorHotel.Models.StatusAcomodacao>()"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ImagemPrincipalUrl" class="form-label"></label>
        <input asp-for="ImagemPrincipalUrl" class="form-control" />
        <span asp-validation-for="ImagemPrincipalUrl" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Fotos adicionais da acomodação</label>
        <input type="text" name="ImagensAcomodacao[0]" class="form-control mb-2" placeholder="URL da Foto 1" />
        <input type="text" name="ImagensAcomodacao[1]" class="form-control mb-2" placeholder="URL da Foto 2" />
        <input type="text" name="ImagensAcomodacao[2]" class="form-control mb-2" placeholder="URL da Foto 3" />
        <input type="text" name="ImagensAcomodacao[3]" class="form-control mb-2" placeholder="URL da Foto 4" />
        <input type="text" name="ImagensAcomodacao[4]" class="form-control mb-2" placeholder="URL da Foto 5" />
    </div>
    <div class="mb-3 form-check">
        <input asp-for="Ativa" class="form-check-input" />
        <label asp-for="Ativa" class="form-check-label"></label>
    </div>
    <!-- Amenidades -->
    <div class="mb-3">
        <label class="form-label">Amenidades</label>
        <div class="row">
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="AmenidadesSelecionadas" value="ar" id="amenidade_ar" />
                    <label class="form-check-label" for="amenidade_ar">
                        <i class="bi bi-snow"></i> Ar-condicionado
                    </label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="AmenidadesSelecionadas" value="wifi" id="amenidade_wifi" />
                    <label class="form-check-label" for="amenidade_wifi">
                        <i class="bi bi-wifi"></i> Wi-Fi
                    </label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="AmenidadesSelecionadas" value="tv" id="amenidade_tv" />
                    <label class="form-check-label" for="amenidade_tv">
                        <i class="bi bi-tv"></i> TV
                    </label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="AmenidadesSelecionadas" value="frigobar" id="amenidade_frigobar" />
                    <label class="form-check-label" for="amenidade_frigobar">
                        <i class="bi bi-cup"></i> Frigobar
                    </label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="AmenidadesSelecionadas" value="ducha" id="amenidade_ducha" />
                    <label class="form-check-label" for="amenidade_ducha">
                        <i class="bi bi-droplet"></i> Ducha
                    </label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="AmenidadesSelecionadas" value="banheira" id="amenidade_banheira" />
                    <label class="form-check-label" for="amenidade_banheira">
                        <i class="bi bi-bucket"></i> Banheira
                    </label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="AmenidadesSelecionadas" value="cozinha" id="amenidade_cozinha" />
                    <label class="form-check-label" for="amenidade_cozinha">
                        <i class="bi bi-house-door"></i> Cozinha
                    </label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="AmenidadesSelecionadas" value="toalha" id="amenidade_toalha" />
                    <label class="form-check-label" for="amenidade_toalha">
                        <i class="bi bi-badge-tm"></i> Toalha
                    </label>
                </div>
            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
